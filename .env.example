# Arc Activity Checker — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

# -------------------------------------------------------
# Arc Network Info (public — safe for frontend)
# -------------------------------------------------------

# Network display name shown in the UI
NEXT_PUBLIC_ARC_NETWORK_NAME=Arc Testnet

# Arc chain ID (number)
NEXT_PUBLIC_ARC_CHAIN_ID=

# Arc block explorer base URL (no trailing slash)
# Example: https://explorer.arc.testnet
NEXT_PUBLIC_ARC_EXPLORER_URL=
# Also set without NEXT_PUBLIC_ for server-side use:
VITE_ARC_EXPLORER_URL=

# -------------------------------------------------------
# Arc Data Sources (SERVER-SIDE ONLY — keep secret)
# -------------------------------------------------------

# 1. Arc RPC URL
#    Used as a fallback when explorer API is unavailable.
#    Example: https://rpc.arc.testnet
ARC_RPC_URL=

# 2. Arc Explorer API base URL (no trailing slash)
#    Supports Etherscan-compatible or Blockscout v2 API format.
#    Example: https://explorer.arc.testnet
ARC_EXPLORER_API_URL=

# 3. Arc Explorer API key (leave blank if not required)
ARC_EXPLORER_API_KEY=

# Optional: Unix timestamp (seconds) of the Arc Testnet launch date.
# Used to calculate "Early Activity" bonus in the Arc Score.
# If not set, the Early Activity category will show "Unavailable".
# Example: 1700000000
ARC_LAUNCH_TIMESTAMP=

# -------------------------------------------------------
# Rate Limiting & Caching (optional — in-memory fallback used if not set)
# -------------------------------------------------------

# Upstash Redis REST URL (for production-scale rate limiting & caching)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=

# -------------------------------------------------------
# App URL
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# -------------------------------------------------------
# Session (required for the API server)
# -------------------------------------------------------
SESSION_SECRET=

# -------------------------------------------------------
# Where to add Arc protocol contracts
# -------------------------------------------------------
# Edit artifacts/api-server/src/lib/arc-protocols.ts
# and add verified Arc ecosystem protocol contract addresses
# to the ARC_PROTOCOLS array.
#
# To add a scam-report data source:
# 1. Find a verified public API that tracks EVM scam reports
# 2. Add the API URL / key as an env var here
# 3. Call it in artifacts/api-server/src/lib/arc-fetcher.ts
#    in the fetchWalletActivity function (scamReports field)
